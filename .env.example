# Copy to .env and fill in. .env is git-ignored (see .gitignore). Never commit real keys.
# FREE-TIER STACK — no Anthropic key (Claude Code runs free on Max; must not be charged),
# no paid OpenAI.
GEMINI_API_KEY=        # PRIMARY — aistudio.google.com/apikey (free)
GROQ_API_KEY=          # FALLBACK — console.groq.com (free)
GITHUB_MODELS_TOKEN=   # THIRD — GitHub PAT with Models:read permission
